PORT=4000
NODE_ENV=development
MONGODB_URI=mongodb://127.0.0.1:27017/appzeto-taxi
JWT_SECRET=replace-me
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
